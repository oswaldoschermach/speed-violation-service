# Copie para docker/prod/.env e defina credenciais fortes antes do deploy:
#   cp docker/prod/.env.example docker/prod/.env

#Apenas exemplo, nao funciona em producao.

POSTGRES_DB=speed_violation
POSTGRES_USER=speed_violation
POSTGRES_PASSWORD=change_me_use_a_strong_password
SERVER_PORT=8080

# No PaaS (Railway, Render, Fly.io), configure diretamente no painel:
# SPRING_PROFILES_ACTIVE=prod
# DB_HOST=<host do Postgres gerenciado>
# DB_PORT=5432
# DB_NAME=speed_violation
# DB_USERNAME=<usuario>
# DB_PASSWORD=<senha>
